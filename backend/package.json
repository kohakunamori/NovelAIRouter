{
  "name": "novelai-router-backend-standalone",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm --filter @novelai-router/shared build && pnpm --filter @novelai-router/api build",
    "dev": "pnpm --filter @novelai-router/shared build && pnpm --filter @novelai-router/api dev",
    "start": "pnpm --filter @novelai-router/api start",
    "typecheck": "pnpm --filter @novelai-router/shared build && pnpm --filter @novelai-router/api typecheck && pnpm --filter @novelai-router/shared typecheck",
    "test": "pnpm --filter @novelai-router/shared test && pnpm --filter @novelai-router/api test",
    "db:generate": "pnpm --filter @novelai-router/api db:generate",
    "db:migrate": "pnpm --filter @novelai-router/api db:migrate",
    "db:seed": "pnpm --filter @novelai-router/api db:seed",
    "novelai:health-check": "pnpm --filter @novelai-router/api novelai:health-check",
    "novelai:smoke-test": "pnpm --filter @novelai-router/api novelai:smoke-test"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp"
    ]
  }
}
