generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum PolicyScope {
  GLOBAL
  ROLE
  USER
}

enum GenerationJobStatus {
  QUEUED
  WAITING_FOR_RESULT_CONSUMER
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum LedgerEntryType {
  ADMIN_GRANT
  GENERATION_DEBIT
  REFUND
}

enum NovelAiAccountStatus {
  ACTIVE
  DISABLED
  COOLDOWN
  ERROR
}

enum NovelAiCredentialKind {
  API_TOKEN
  SESSION_COOKIE
  CUSTOM_JSON
}

enum AssetKind {
  REFERENCE_IMAGE
  GENERATED_IMAGE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  balance      Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  sessions              Session[]
  generationJobs        GenerationJob[]
  ledgerEntries         LedgerEntry[]
  assets                Asset[]
  promptChunkLibrary    UserPromptChunkLibrary?

  @@index([role])
  @@index([status])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PlatformSettings {
  id              String   @id @default("default")
  anlasMultiplier Decimal  @default(1.0) @db.Decimal(10, 4)
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserPromptChunkLibrary {
  id          String   @id @default(cuid())
  userId      String   @unique
  libraryJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model ParameterPolicy {
  id              String      @id @default(cuid())
  name            String
  scope           PolicyScope
  role            UserRole?
  userId          String?
  priority        Int         @default(0)
  enabled         Boolean     @default(true)
  rulesJson       Json
  version         Int         @default(1)
  createdByUserId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([scope, enabled, priority])
  @@index([userId])
  @@index([role])
}

model NovelAiAccount {
  id                              String               @id @default(cuid())
  label                           String
  status                          NovelAiAccountStatus @default(ACTIVE)
  credentialKind                  NovelAiCredentialKind
  credentialCiphertext            String
  credentialIv                    String
  credentialAuthTag               String
  credentialKeyVersion            Int                  @default(1)
  priority                        Int                  @default(0)
  maxConcurrentJobs               Int                  @default(1)
  cooldownUntil                   DateTime?
  lastUsedAt                      DateTime?
  lastCheckedAt                   DateTime?
  lastSuccessAt                   DateTime?
  lastFailureAt                   DateTime?
  failureCount                    Int                  @default(0)
  lastErrorCode                   String?
  lastErrorMessage                String?
  remoteAccountLabel              String?
  remoteAnlasBalance              Int?
  remoteTier                      Int?
  remoteActive                    Boolean?
  remoteUnlimitedImageGeneration  Boolean?
  remoteMaxPriorityActions        Int?
  remoteFixedTrainingStepsLeft    Int?
  remotePurchasedTrainingSteps    Int?
  createdByUserId                 String?
  updatedByUserId                 String?
  createdAt                       DateTime             @default(now())
  updatedAt                       DateTime             @updatedAt

  generationJobs GenerationJob[]

  @@index([status, priority])
  @@index([cooldownUntil])
}

model GenerationJob {
  id                         String              @id @default(cuid())
  userId                     String
  novelAiAccountId           String?
  status                     GenerationJobStatus @default(QUEUED)
  submittedParamsJson        Json
  normalizedParamsJson       Json?
  policyVersion              Int?
  policyDecisionJson         Json?
  novelAiRequestId           String?
  estimatedNovelAiAnlas      Int?
  actualNovelAiAnlas         Int?
  platformMultiplierSnapshot Decimal?            @db.Decimal(10, 4)
  billedPlatformUnits        Int?
  resultMimeType             String?
  intermediateOutputCount    Int                 @default(0)
  intermediateOutputSseBytes Int                 @default(0)
  errorCode                  String?
  errorMessage               String?
  createdAt                  DateTime            @default(now())
  startedAt                  DateTime?
  completedAt                DateTime?

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  novelAiAccount NovelAiAccount?  @relation(fields: [novelAiAccountId], references: [id], onDelete: SetNull)
  ledgerEntries  LedgerEntry[]
  outputs        GenerationOutput[]

  @@index([userId, createdAt])
  @@index([novelAiAccountId])
  @@index([status])
}

model Asset {
  id               String             @id @default(cuid())
  userId           String
  kind             AssetKind
  mimeType         String
  byteSize         Int
  originalFilename String?
  storageKey       String             @unique
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationOutputs GenerationOutput[]

  @@index([userId, kind, createdAt])
}

model GenerationOutput {
  id              String   @id @default(cuid())
  generationJobId String
  assetId         String
  index           Int
  createdAt       DateTime @default(now())

  generationJob GenerationJob @relation(fields: [generationJobId], references: [id], onDelete: Cascade)
  asset         Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([generationJobId, index])
  @@index([assetId])
}

model LedgerEntry {
  id              String          @id @default(cuid())
  userId          String
  generationJobId String?
  type            LedgerEntryType
  novelAiAnlas    Int?
  multiplier      Decimal?        @db.Decimal(10, 4)
  platformUnits   Int
  balanceAfter    Int
  createdByUserId String?
  createdAt       DateTime        @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJob GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([generationJobId])
  @@index([type])
}
